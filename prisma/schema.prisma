generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          Int         @id @default(autoincrement())
  githubId    Int         @unique
  name        String
  fullName    String
  description String?
  htmlUrl     String
  stargazersCount Int     @default(0)
  forksCount  Int         @default(0)
  language    String?
  ownerLogin  String
  ownerAvatarUrl String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now())
  pushedAt    DateTime?
  collections Collection[]
  
  @@index([githubId])
  @@index([stargazersCount])
}

model Collection {
  id          Int      @id @default(autoincrement())
  githubId    Int
  project     Project  @relation(fields: [githubId], references: [githubId], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@unique([githubId])
}
